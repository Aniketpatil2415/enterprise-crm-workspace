//
// FUSION BYTE CRM ENTERPRISE DATABASE SCHEMA (PHASE 4: AUDIT ENGINE)
//

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==========================================
// ENUMS (Strict State Machines)
// ==========================================

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum DealStage {
  DISCOVERY
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

// ==========================================
// CORE TENANT ARCHITECTURE
// ==========================================

model Workspace {
  id        String   @id @default(uuid())
  tenantUid String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  // Relational Web
  users     User[]
  leads     Lead[]
  companies Company[]
  contacts  Contact[]
  deals     Deal[]
  tasks     Task[]
  notes     Note[]
  invites WorkspaceInvite[]
  apiKeys ApiKey[]

  @@index([tenantUid])
}

model User {
  id          String   @id @default(uuid())
  firebaseUid   String    @unique
  workspaceId String
  email       String   @unique
  fullName    String
  role        Role     @default(MEMBER)
  
  isSuperAdmin  Boolean   @default(false)

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Relationships
  workspace     Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdLeads  Lead[]    @relation("UserToLead")
  ownedDeals    Deal[]    @relation("UserToDeal")
  assignedTasks Task[]    @relation("UserToTask")
  createdNotes  Note[]    @relation("UserToNote")

  @@index([workspaceId])
  @@index([firebaseUid])
}

// ==========================================
// PHASE 1: PIPELINE ENGINE
// ==========================================

model Lead {
  id              String     @id @default(uuid())
  workspaceId     String
  createdByUserId String
  firstName       String
  lastName        String?
  email           String?
  phone           String?
  status          LeadStatus @default(NEW)
  order           Int        @default(0)
  source          String     @default("MANUAL")
  
  isDeleted       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @default(now()) @updatedAt

  // Relationships
  workspace       Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User       @relation("UserToLead", fields: [createdByUserId], references: [id])
  notes           Note[]

  @@index([workspaceId])
  @@index([status])
}

// ==========================================
// PHASE 2: THE RELATIONAL WEB
// ==========================================

model Company {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  industry    String?
  website     String?
  address     String?
  
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Relationships
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts    Contact[]
  deals       Deal[]
  notes       Note[]

  @@index([workspaceId])
}

model Contact {
  id          String   @id @default(uuid())
  workspaceId String
  companyId   String?  
  firstName   String
  lastName    String?
  email       String?
  phone       String?
  title       String?  
  
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  // Relationships
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company     Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals       Deal[]
  notes       Note[]

  @@index([workspaceId])
  @@index([companyId])
}

model Deal {
  id                String    @id @default(uuid())
  workspaceId       String
  companyId         String?
  contactId         String?
  ownerId           String    
  title             String    
  value             Float     @default(0.0)
  stage             DealStage @default(DISCOVERY)
  expectedCloseDate DateTime?
  
  isDeleted         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @default(now()) @updatedAt

  // Relationships
  workspace         Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company           Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact           Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  owner             User      @relation("UserToDeal", fields: [ownerId], references: [id])
  tasks             Task[]
  notes             Note[]

  @@index([workspaceId])
  @@index([ownerId])
  @@index([stage])
}

// ==========================================
// PHASE 3: THE ACTION ENGINE (TASKS)
// ==========================================

model Task {
  id          String       @id @default(uuid())
  workspaceId String
  assigneeId  String
  dealId      String?
  title       String
  description String?      @db.Text
  status      TaskStatus   @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  
  isDeleted   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt

  // Relationships
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignee    User         @relation("UserToTask", fields: [assigneeId], references: [id])
  deal        Deal?        @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([assigneeId])
  @@index([dealId])
}

// ==========================================
// PHASE 4: THE AUDIT & NOTES ENGINE (NEW)
// ==========================================

model Note {
  id              String   @id @default(uuid())
  workspaceId     String
  createdByUserId String
  content         String   @db.Text
  isSystem        Boolean  @default(false) // If true, it's an auto-generated audit log
  
  // Polymorphic Links (Can belong to any ONE of these)
  leadId          String?
  companyId       String?
  contactId       String?
  dealId          String?

  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  // Relationships
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User      @relation("UserToNote", fields: [createdByUserId], references: [id])
  
  lead            Lead?     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  company         Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact         Contact?  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal            Deal?     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([leadId])
  @@index([companyId])
  @@index([contactId])
  @@index([dealId])
}

// ==========================================
// PHASE 5: TEAM & INVITE ENGINE
// ==========================================

model WorkspaceInvite {
  id          String   @id @default(uuid())
  workspaceId String
  token       String   @unique // The secure encrypted token
  email       String?  // Optional: If you want to invite a specific email
  role        Role     @default(MEMBER)
  expiresAt   DateTime // Link will die after 7 days
  isUsed      Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([token])
}
// PHASE 6: API GATEWAY & WEBHOOKS
model ApiKey {
  id          String    @id @default(uuid())
  workspaceId String
  name        String
  key         String    @unique
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([key])
  @@index([workspaceId])
}
// ==========================================
// ADVANCED SAAS FEATURES
// ==========================================
model Announcement {
  id          String   @id @default(uuid())
  title       String
  message     String
  type        String   @default("INFO") // Types: INFO, WARNING, SUCCESS
  targetEmail String?  // Optional: Agar kisi specific user ko warning deni ho
  createdAt   DateTime @default(now())
}